<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SocietyMart Admin - Login</title>
  <!-- Bootstrap 5 CDN -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">
  <!-- Google Fonts: Plus Jakarta Sans (Calming and premium) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body {
      background: linear-gradient(135deg, #FFF0F5 0%, #FFE4E1 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }
    .login-card {
      border: none;
      border-radius: 20px;
      box-shadow: 0 10px 30px rgba(231, 84, 128, 0.15);
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(10px);
      width: 100%;
      max-width: 420px;
      overflow: hidden;
    }
    .login-header {
      background: #e75480;
      color: white;
      padding: 30px 20px;
      text-align: center;
    }
    .login-header h3 {
      font-weight: 700;
      margin: 0;
      letter-spacing: 0.5px;
    }
    .login-body {
      padding: 40px 30px;
    }
    .form-control {
      border-radius: 10px;
      padding: 12px 15px;
      border: 1px solid #f0f0f0;
      background-color: #fafafa;
      transition: all 0.2s ease;
    }
    .form-control:focus {
      border-color: #e75480;
      box-shadow: 0 0 0 0.25rem rgba(231, 84, 128, 0.25);
      background-color: #fff;
    }
    .btn-login {
      background-color: #e75480;
      color: white;
      border-radius: 10px;
      padding: 12px;
      font-weight: 600;
      border: none;
      transition: all 0.3s ease;
      width: 100%;
    }
    .btn-login:hover {
      background-color: #d13d6a;
      transform: translateY(-2px);
      box-shadow: 0 5px 15px rgba(231, 84, 128, 0.3);
    }
    .brand-icon {
      font-size: 2.5rem;
      margin-bottom: 10px;
      color: white;
    }
  </style>
</head>
<body>

  <div class="login-card">
    <div class="login-header">
      <i class="bi bi-shield-lock-fill brand-icon"></i>
      <h3>SOCIETY MART</h3>
      <p class="mb-0 text-white-50">Control Center Access</p>
    </div>
    
    <div class="login-body">
      <% if (locals.error) { %>
        <div class="alert alert-danger d-flex align-items-center" role="alert">
          <i class="bi bi-exclamation-triangle-fill me-2"></i>
          <div><%= error %></div>
        </div>
      <% } %>

      <form action="/login" method="POST">
        <div class="mb-3">
          <label for="username" class="form-label text-muted fw-bold small">ADMIN USERNAME</label>
          <div class="input-group">
            <span class="input-group-text bg-white border-end-0" style="border-radius: 10px 0 0 10px; border-color: #f0f0f0;"><i class="bi bi-person-fill text-muted"></i></span>
            <input type="text" class="form-control border-start-0" id="username" name="username" placeholder="Enter admin username" required style="border-radius: 0 10px 10px 0;">
          </div>
        </div>
        
        <div class="mb-4">
          <label for="password" class="form-label text-muted fw-bold small">PASSWORD</label>
          <div class="input-group">
            <span class="input-group-text bg-white border-end-0" style="border-radius: 10px 0 0 10px; border-color: #f0f0f0;"><i class="bi bi-lock-fill text-muted"></i></span>
            <input type="password" class="form-control border-start-0" id="password" name="password" placeholder="Enter password" required style="border-radius: 0 10px 10px 0;">
          </div>
        </div>

        <button type="submit" class="btn btn-login mb-3">Sign In Securely</button>
      </form>
      
      <div class="text-center">
        <span class="text-muted small">SocietyMart Admin Panel v1.0</span>
      </div>
    </div>
  </div>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
