<%- include('partials/header') %>

<div class="row align-items-center mb-4">
  <div class="col">
    <h2 class="h3 mb-0 text-gray-800 fw-bold">Manage Home Kitchens</h2>
    <p class="text-muted mb-0">Audit registered neighborhood kitchens (sellers) operating inside societies</p>
  </div>
</div>

<% if (locals.successMsg) { %>
  <div class="alert alert-success alert-dismissible fade show d-flex align-items-center mb-4" role="alert">
    <i class="bi bi-check-circle-fill me-2"></i>
    <div><%= successMsg %></div>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<div class="card premium-card p-4">
  <h5 class="fw-bold mb-3">Seller Kitchen Directory</h5>
  
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead class="table-light">
        <tr>
          <th scope="col" style="border-radius: 8px 0 0 8px;">KITCHEN / CHEF NAME</th>
          <th scope="col">PHONE</th>
          <th scope="col">EMAIL</th>
          <th scope="col">SOCIETY</th>
          <th scope="col">FLAT / VILLA</th>
          <th scope="col" class="text-center" style="border-radius: 0 8px 8px 0; width: 120px;">ACTIONS</th>
        </tr>
      </thead>
      <tbody>
        <% if (kitchens && kitchens.length > 0) { %>
          <% kitchens.forEach(function(kitchen) { %>
            <tr>
              <td>
                <div class="d-flex align-items-center gap-2">
                  <div class="rounded bg-light p-2 text-center" style="width: 40px; height: 40px; color: #198754;">
                    <i class="bi bi-egg-fried"></i>
                  </div>
                  <div>
                    <div class="fw-bold text-dark"><%= kitchen.full_name %></div>
                    <span class="text-muted small">Seller ID: <%= kitchen.id %></span>
                  </div>
                </div>
              </td>
              <td><a href="tel:<%= kitchen.phone %>" class="text-decoration-none text-muted small"><%= kitchen.phone %></a></td>
              <td><span class="text-muted small"><%= kitchen.email || 'N/A' %></span></td>
              <td>
                <span class="badge badge-pink py-2 px-3 rounded-pill small">
                  <%= kitchen.societyName || 'N/A' %>
                </span>
              </td>
              <td><code><%= kitchen.flat_number || 'N/A' %></code></td>
              <td class="text-center">
                <form action="/kitchens/delete/<%= kitchen.id %>" method="POST" onsubmit="return confirm('Are you sure you want to terminate this seller account? This will also remove all their active food listings!');">
                  <button type="submit" class="btn btn-sm btn-outline-danger border-0 rounded-circle" style="width: 32px; height: 32px; padding: 0;">
                    <i class="bi bi-trash3-fill"></i>
                  </button>
                </form>
              </td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr>
            <td colspan="6" class="text-center py-5 text-muted">
              <i class="bi bi-egg-fried text-muted d-block fs-1 mb-2" style="opacity: 0.3;"></i>
              No active seller kitchens registered.
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('partials/footer') %>
